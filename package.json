{
	"name": "schoolflow-api",
	"version": "1.0.0",
	"homepage": "https://github.com/AlanNRZBV/schoolflow-api#readme",
	"bugs": {
		"url": "https://github.com/AlanNRZBV/schoolflow-api/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AlanNRZBV/schoolflow-api.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc -b && tsc-alias",
		"start": "node dist/index.js",
		"dev": "tsx watch --env-file=.env src/index.ts",
		"seed:schools": "ts-node -r tsconfig-paths/register src/lib/db/seed.schools.ts",
		"seed:subjects": "ts-node -r tsconfig-paths/register src/lib/db/seed.subjects.ts",
		"seed:users": "ts-node -r tsconfig-paths/register src/lib/db/seed.users.ts",
		"gen:users": "ts-node -r tsconfig-paths/register src/lib/db/generate.users.staff.ts"
	},
	"dependencies": {
		"@types/chance": "^1.1.7",
		"@types/nodemailer": "^7.0.10",
		"bcryptjs": "^3.0.3",
		"celebrate": "^15.0.3",
		"chance": "^1.1.13",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.1",
		"nodemailer": "^8.0.1",
		"ts-node": "^10.9.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.3.0",
		"eslint": "^10.0.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	}
}
